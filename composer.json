{
    "name": "onaonbir/oo-subscription",
    "version": "1.0.0",
    "description": "Backend-only subscription management package for Laravel. Supports polymorphic subscribables, immutable subscription rows, multi-language content, multi-currency pricing, feature usage tracking with overage billing, and a pluggable payment gateway contract.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "subscription",
        "billing",
        "saas",
        "feature-flags",
        "usage-tracking",
        "multi-currency",
        "overage-billing"
    ],
    "homepage": "https://onaonbir.com",
    "support": {
        "issues": "https://github.com/onaonbir/oo-subscription/issues",
        "source": "https://github.com/onaonbir/oo-subscription"
    },
    "authors": [
        {
            "name": "OnaOnbir",
            "email": "dev@onaonbir.com",
            "homepage": "https://onaonbir.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0 || ^12.0",
        "illuminate/support": "^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "OnaOnbir\\Subscription\\": "src/",
            "OnaOnbir\\Subscription\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OnaOnbir\\Subscription\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OnaOnbir\\Subscription\\SubscriptionServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
